# All plans default to "Free" in variables.tf — override here only once you
# actually have a matching resource type deployed. Example, once you have a
# VM to protect:
# defender_plans = {
#   VirtualMachines = "Standard"
#   AppServices     = "Free"
#   SqlServers      = "Free"
#   StorageAccounts = "Free"
#   KeyVaults       = "Free"
#   Containers      = "Free"
#   Arm             = "Free"
#   Dns             = "Free"
# }
